# ── Cat Supremacy Bot ─────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Discord (required) ───────────────────────────────────
DISCORD_TOKEN=
CAT_CHANNEL_ID=

# ── API Keys (optional — enables AI & higher cat-API limits)
CAT_API_KEY=
OPENAI_API_KEY=

# ── AI Models (optional — defaults shown) ────────────────
CHAT_MODEL=gpt-4.1-mini
EXTRACTION_MODEL=gpt-4.1-nano
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Vector Memory / ChromaDB (optional) ──────────────────
CHROMA_PERSIST_DIR=./data/chroma_data
MEMORY_TOP_K=5
MAX_MEMORIES_PER_USER=150

# ── Challenges (optional) ────────────────────────────────
CHALLENGE_REMINDER_HOURS=4